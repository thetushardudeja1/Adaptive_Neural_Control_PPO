<mujoco model="industrial_2dof_arm">

    <option gravity="0 0 -9.81"
            timestep="0.002"
            integrator="RK4"/>

    <visual>
        <map znear="0.01"/>
    </visual>

    <worldbody>

        <!-- Ground -->
        <geom type="plane"
              size="5 5 0.1"
              rgba="0.9 0.9 0.9 1"/>

        <!-- Lighting -->
        <light pos="0 0 3"
               dir="0 0 -1"/>

        <!-- Base -->
        <body name="base" pos="0 0 0.2">
            <geom type="cylinder"
                  size="0.2 0.2"
                  rgba="0.2 0.2 0.2 1"/>

            <!-- Joint 1 -->
            <body name="joint1_body" pos="0 0 0">
                <joint name="joint1"
                       type="hinge"
                       axis="0 1 0"
                       damping="0.6"/>

                <geom type="cylinder"
                      size="0.1 0.1"
                      rgba="0.1 0.1 0.1 1"/>

                <!-- Link 1 -->
                <body name="link1" pos="0 0 -0.1">
                    <geom type="box"
                          size="0.04 0.04 0.35"
                          pos="0 0 -0.35"
                          rgba="0.8 0.2 0.2 1"
                          density="500"/>

                    <!-- Joint 2 -->
                    <body name="joint2_body" pos="0 0 -0.7">
                        <joint name="joint2"
                               type="hinge"
                               axis="0 1 0"
                               damping="0.6"/>

                        <geom type="cylinder"
                              size="0.08 0.08"
                              rgba="0.1 0.1 0.1 1"/>

                        <!-- Link 2 -->
                        <body name="link2" pos="0 0 -0.08">
                            <geom type="box"
                                  size="0.03 0.03 0.30"
                                  pos="0 0 -0.30"
                                  rgba="0.2 0.2 0.8 1"
                                  density="500"/>
                        </body>

                    </body>
                </body>

            </body>
        </body>

    </worldbody>

    <!-- Strong Actuators -->
    <actuator>
        <motor joint="joint1" ctrlrange="-500 500"/>
        <motor joint="joint2" ctrlrange="-500 500"/>
    </actuator>

</mujoco>